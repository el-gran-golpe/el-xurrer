# BaseLLM Keys
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

GITHUB_API_KEY_HARU=
GITHUB_API_KEY_CHARLY=
GITHUB_API_KEY_MOI=

# ── Fanvue Accounts ────────────────────────────────────────────────────────────
# Legacy Selenium credentials (used by the fallback Selenium publisher only)
# Pattern: {PROFILE}_FANVUE_USERNAME / {PROFILE}_FANVUE_PASSWORD
LAURA_VIGNE_FANVUE_USERNAME=
LAURA_VIGNE_FANVUE_PASSWORD=
MARIA_LARSEN_FANVUE_USERNAME=
MARIA_LARSEN_FANVUE_PASSWORD=

# Per-profile OAuth credentials (used by the OAuth API publisher and CLI token refresh)
# Each Fanvue account requires its own OAuth app registration from the Fanvue developer portal.
# Pattern: FANVUE_WEBAPP_{PROFILE}_OAUTH_CLIENT_ID / _CLIENT_SECRET
# where {PROFILE} is the uppercased profile name (laura_vigne → LAURA_VIGNE)
FANVUE_WEBAPP_LAURA_VIGNE_OAUTH_CLIENT_ID=
FANVUE_WEBAPP_LAURA_VIGNE_OAUTH_CLIENT_SECRET=
FANVUE_WEBAPP_MARIA_LARSEN_OAUTH_CLIENT_ID=
FANVUE_WEBAPP_MARIA_LARSEN_OAUTH_CLIENT_SECRET=

# Shared FastAPI OAuth settings (same values as in fanvue-fastapi/.env)
FANVUE_WEBAPP_OAUTH_REDIRECT_URI=http://localhost:8000/api/oauth/callback
FANVUE_WEBAPP_OAUTH_ISSUER_BASE_URL=https://auth.fanvue.com
FANVUE_WEBAPP_SESSION_SECRET=
FANVUE_WEBAPP_API_BASE_URL=https://api.fanvue.com
FANVUE_WEBAPP_BASE_URL=http://localhost:8000


# Google Drive OAuth
client_id=
client_secret=

# Google Drive folder
folder_id=


# Instagram Login publishing and shared Facebook staging
# Per-profile Instagram Login values are still required for publishing.
# {PROFILE}_INSTAGRAM_ACCOUNT_ID=
# {PROFILE}_INSTAGRAM_USER_ACCESS_TOKEN=
# Shared Facebook staging credentials are used only to generate public media
# URLs for Instagram publishing. They are not per-profile values.
# Use a direct Page access token for the staging Page, not a short-lived user token.
# FACEBOOK_STAGING_PAGE_ID=
# FACEBOOK_STAGING_PAGE_ACCESS_TOKEN=
LAURA_VIGNE_INSTAGRAM_ACCOUNT_ID=
LAURA_VIGNE_INSTAGRAM_USER_ACCESS_TOKEN=
MARIA_LARSEN_INSTAGRAM_ACCOUNT_ID=
MARIA_LARSEN_INSTAGRAM_USER_ACCESS_TOKEN=
FACEBOOK_STAGING_PAGE_ID=
FACEBOOK_STAGING_PAGE_ACCESS_TOKEN=


# ComfyUI server (leave unset to use local; set COMFY_HOST to a ZeroTier IP to use a remote machine)
COMFY_HOST=127.0.0.1
COMFY_PORT=8188

# BaseLLM Keys
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

GITHUB_API_KEY_HARU=
GITHUB_API_KEY_CHARLY=
GITHUB_API_KEY_MOI=

#FanVUE Accounts
# Every account must have its own username and password variable following the pattern below
# {PROFILE}_FANVUE_USERNAME=
# {PROFILE}_FANVUE_PASSWORD=
LAURA_VIGNE_FANVUE_USERNAME=
LAURA_VIGNE_FANVUE_PASSWORD=
MARIA_LARSEN_FANVUE_USERNAME=
MARIA_LARSEN_FANVUE_PASSWORD=


# Google Drive OAuth
client_id=
client_secret=

# My Drive folder
folder_id=


# Instagram Login publishing and shared Facebook staging
# Per-profile Instagram Login values are still required for publishing.
# {PROFILE}_INSTAGRAM_ACCOUNT_ID=
# {PROFILE}_INSTAGRAM_USER_ACCESS_TOKEN=
# Shared Facebook staging credentials are used only to generate public media
# URLs for Instagram publishing. They are not per-profile values.
# Use a direct Page access token for the staging Page, not a short-lived user token.
# FACEBOOK_STAGING_PAGE_ID=
# FACEBOOK_STAGING_PAGE_ACCESS_TOKEN=
LAURA_VIGNE_INSTAGRAM_ACCOUNT_ID=
LAURA_VIGNE_INSTAGRAM_USER_ACCESS_TOKEN=
MARIA_LARSEN_INSTAGRAM_ACCOUNT_ID=
MARIA_LARSEN_INSTAGRAM_USER_ACCESS_TOKEN=
FACEBOOK_STAGING_PAGE_ID=
FACEBOOK_STAGING_PAGE_ACCESS_TOKEN=


# ComfyUI server (leave unset to use local; set COMFY_HOST to a ZeroTier IP to use a remote machine)
COMFY_HOST=127.0.0.1
COMFY_PORT=8188

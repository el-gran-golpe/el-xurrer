# OAuth Credentials (from Fanvue Developer Area)
OAUTH_CLIENT_ID=your_client_id
OAUTH_CLIENT_SECRET=your_client_secret
OAUTH_REDIRECT_URI=http://localhost:8000/api/oauth/callback
OAUTH_SCOPES=read:self

# Session Configuration
SESSION_SECRET=change_this_to_a_secure_random_string_min_16_chars
SESSION_COOKIE_NAME=fvsession

# API Configuration
OAUTH_ISSUER_BASE_URL=https://auth.fanvue.com
API_BASE_URL=https://api.fanvue.com
BASE_URL=http://localhost:8000

# AI Content Pipeline environment example.
# Copy the variables you need into the repository root .env.

# LLM providers
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# GitHub Models keys. Add any profile/user-specific keys you use.
GITHUB_API_KEY_HARU=
GITHUB_API_KEY_CHARLY=
GITHUB_API_KEY_MOI=

# Google Drive resource sync
client_id=
client_secret=
folder_id=

# Optional runtime overrides
# AI_CONTENT_RESOURCES_DIR=/absolute/path/to/resources
COMFY_HOST=127.0.0.1
COMFY_PORT=8188

# Instagram Login publishing and shared Facebook staging
LAURA_VIGNE_INSTAGRAM_ACCOUNT_ID=
LAURA_VIGNE_INSTAGRAM_USER_ACCESS_TOKEN=
MARIA_LARSEN_INSTAGRAM_ACCOUNT_ID=
MARIA_LARSEN_INSTAGRAM_USER_ACCESS_TOKEN=
FACEBOOK_STAGING_PAGE_ID=
FACEBOOK_STAGING_PAGE_ACCESS_TOKEN=

# Fanvue per-profile OAuth credentials used by Fanvue publishing/auth
FANVUE_WEBAPP_LAURA_VIGNE_OAUTH_CLIENT_ID=
FANVUE_WEBAPP_LAURA_VIGNE_OAUTH_CLIENT_SECRET=
FANVUE_WEBAPP_MARIA_LARSEN_OAUTH_CLIENT_ID=
FANVUE_WEBAPP_MARIA_LARSEN_OAUTH_CLIENT_SECRET=

# Shared Fanvue OAuth/API settings
FANVUE_WEBAPP_OAUTH_REDIRECT_URI=http://localhost:8000/api/oauth/callback
FANVUE_WEBAPP_OAUTH_SCOPES=read:self
FANVUE_WEBAPP_OAUTH_ISSUER_BASE_URL=https://auth.fanvue.com
FANVUE_WEBAPP_API_BASE_URL=https://api.fanvue.com
FANVUE_WEBAPP_BASE_URL=http://localhost:8000

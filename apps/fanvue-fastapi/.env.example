# Fanvue FastAPI environment example.
# Copy the variables you need into the repository root .env or this app's .env.

# Per-profile OAuth credentials
FANVUE_WEBAPP_LAURA_VIGNE_OAUTH_CLIENT_ID=
FANVUE_WEBAPP_LAURA_VIGNE_OAUTH_CLIENT_SECRET=
FANVUE_WEBAPP_MARIA_LARSEN_OAUTH_CLIENT_ID=
FANVUE_WEBAPP_MARIA_LARSEN_OAUTH_CLIENT_SECRET=

# Shared OAuth configuration
FANVUE_WEBAPP_OAUTH_REDIRECT_URI=http://localhost:8000/api/oauth/callback
FANVUE_WEBAPP_OAUTH_SCOPES=read:self
FANVUE_WEBAPP_OAUTH_ISSUER_BASE_URL=https://auth.fanvue.com
# FANVUE_WEBAPP_OAUTH_RESPONSE_MODE=
# FANVUE_WEBAPP_OAUTH_PROMPT=

# Session
FANVUE_WEBAPP_SESSION_SECRET=change_this_to_a_secure_random_string
FANVUE_WEBAPP_SESSION_COOKIE_NAME=fvsession

# Fanvue API
FANVUE_WEBAPP_API_BASE_URL=https://api.fanvue.com
FANVUE_WEBAPP_BASE_URL=http://localhost:8000
# FANVUE_WEBAPP_RESOURCES_ROOT=/absolute/path/to/resources

# Optional local server settings
SERVER_HOST=127.0.0.1
SERVER_PORT=8000
RELOAD=true
